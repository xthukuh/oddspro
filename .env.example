# MySQL connection
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=oddspro
DB_USERNAME=root
DB_PASSWORD=
DB_CHARSET=utf8mb4
DB_COLLATION=utf8mb4_unicode_ci

# API-Football via api-sports.io (https://dashboard.api-football.com)
X_APISPORTS_URL=https://v3.football.api-sports.io
X_APISPORTS_KEY=your-api-key

# AI adjudicators (hot picks + tips) - optional Google Gemini (https://aistudio.google.com/apikey).
# No key = rules-only verdicts. Keep the real key here (gitignored), never in git.
#GEMINI_API_KEY=your-gemini-key
#GEMINI_URL=https://generativelanguage.googleapis.com/v1beta
#HOTPICK_AI_MODEL=gemini-2.5-flash
#HOTPICK_AI_WEB=0            # 1 = ground verdicts with Gemini's google_search tool (grounded calls bill extra)
#TIP_AI_MIN_CONFIDENCE=0.75  # tip AI review: only tips at/above this confidence
#TIP_AI_DAILY_CAP=20         # tip AI review: max fresh (billed) verdicts per EAT day (worker-enforced; cached/reused verdicts don't count)
#HOTPICK_AI_CONCURRENCY=4    # AI-review worker: calls in flight (network-bound, not DB-bound)
#TIP_AI_REUSE_PRICE_TOL=0    # reuse a stored tip verdict while price drift stays within this relative fraction (0 = exact; 0.05 = ~5%)

# --- M4.1 AI enrichment (collection only; nothing feeds ranking) ------------
#OPENROUTER_API_KEY=            # secret - .env ONLY, never the settings catalog
#OPENROUTER_URL=https://openrouter.ai/api/v1
#OPENROUTER_MODEL=openai/gpt-5.6-terra   # MUST be non-Google: two Google models agreeing is Gemini agreeing with itself.
                                         # openrouter/auto + openrouter/free are auto-routers (model varies per call) - disqualified.
#AI_ENRICH_ENABLED=0           # 1 = run the 3-call enrichment set per upcoming fixture
#AI_ENRICH_CAP=200             # FIXTURES per run (never truncates a fixture mid-set)
#AI_ENRICH_CONCURRENCY=4       # fixtures in flight; calls are network-bound, not DB-bound
#AI_BLIND_MODEL=               # blank = provider default
#AI_ANCHORED_MODEL=            # blank = provider default

# --- AI safety harness (Detour B; applies to adjudicators + enrichment) -----
#AI_RUN_MAX_MINUTES=0          # per-run AI wall-clock budget in minutes (0 = off; the daily/run caps already bound call counts)
#AI_BREAKER_AFTER=5            # circuit breaker: N consecutive transport/parse failures refuse the rest of the run (0 = off)

# Optional overrides
#BETPAWA_BASE_URL=https://www.betpawa.co.ke/api/sportsbook/v4
#BETIKA_BASE_URL=https://api.betika.com/v1/uo
#APISPORTS_MIN_REMAINING=5
#LINK_MIN_CONFIDENCE=0.85
#PREMATCH_TEAM_WINDOW=5  # rolling window: each team's last N games vs all other teams
#PREMATCH_H2H_WINDOW=5   # rolling window: last N head-to-head meetings
#HOTPICK_TEAM_WINDOW=7         # hot picks: rolling last-N games per team (keep <= 8, see history backfill)
#HOTPICK_MIN_GAMES=5           # hot picks: minimum sample per team
#HOTPICK_MIN_OVER_RATE=0.6     # hot picks: min share of last-N games with 3+ goals
#HOTPICK_MIN_AVG_TOTAL=3.2     # hot picks: min avg total goals per game
#HOTPICK_MIN_IMPLIED_OVER=0.52 # hot picks: min vig-removed market P(over 2.5)
#HOTPICK_H2H_MIN_OVER_RATE=0.4 # hot picks: H2H veto floor (3+ meetings)
#HOTPICK_LINES=2.5             # hot picks: CSV of O/U lines to evaluate per fixture (scoreOverLine, M3).
                               # Stays 2.5 by design. The Task 10 warehouse sweep (backtest-hotpicks.js
                               # --line 1.5,2.5,3.5, 28,340 fixtures) found: 2.5 best gate 73.1% (+18.7pp
                               # over baseline), 3.5 only 63.9% (below the ~73% bar), and 1.5 88.5% but on
                               # a 76.4% baseline (+12.0pp) - AND its scores run ~0.92 vs 2.5's ~0.80, so
                               # adding it would let the loop's strictly-higher-score rule silently replace
                               # over-2.5 picks with trivial ~1.1-odds over-1.5 bets (a product regression,
                               # not a gain). So NO line but 2.5 has a LINE_THRESHOLDS entry in
                               # src/db/goals-rules.js. A line listed here without one is inert (never fires
                               # hot); to add one, re-run the sweep and tune its LINE_THRESHOLDS entry first.
#TIP_MIN_PRICE=1.2             # tip column: exclude near-certain junk odds below this price
#TIP_MIN_CONFIDENCE=0.5        # tip column: show no tip below this blended confidence
#TIP_MIN_UNDER_LINE=4.5        # tip column: no Under tips below this O/U line (near-Unders have no edge)
#TIP_MIN_OVERROUND=1.01        # tip column: family book min implied-probability sum (below = palp error/boost)
#TIP_MAX_OVERROUND=1.30        # tip column: family book max implied-probability sum (above = margin-loaded)
#TIP_MAX_BOOK_DIVERGENCE=0.15  # tip column: max cross-provider devigged-probability gap before a divergence veto
#API_PORT=3001       # PORT wins if API_PORT is unset (cPanel/Passenger assigns PORT automatically)
#API_HOST=127.0.0.1  # set 0.0.0.0 to expose the dashboard (and its refresh endpoint) on the LAN
                      # - leave at 127.0.0.1 on cPanel/Passenger, it proxies over loopback
#API_TOKEN=           # optional: require `Authorization: Bearer <token>` on /api/* once public
                      # (web/src/api.js sends it from VITE_API_TOKEN, baked in at build time)
#ADMIN_TOKEN=         # optional: admin secret for the traffic dashboard (GET /admin +
                      # GET /api/visits/summary). Separate from API_TOKEN so a public SPA
                      # stays open while the admin views are locked; falls back to API_TOKEN.
                      # Unset (and no API_TOKEN) = admin dashboard returns 404 (off).
#DEBUG=0              # 1 = verbose per-step timing logs (pipeline runs) - the main diagnostic
                      # channel on hosts with no SSH/live tailing (e.g. cPanel cron)
#REFRESH_COOLDOWN_MINUTES=60  # POST /api/refresh: blocks re-triggering the SAME date again
                              # until this long after its last run finished. 0 = disabled.

# In-process auto-refresh scheduler (runs inside `npm run serve` - set
# AUTO_REFRESH_ENABLED=0 in local dev to avoid background scraping/API spend).
#AUTO_REFRESH_ENABLED=1  # master switch for the scheduler
#AUTO_LIGHT_MINUTES=10   # light pass cadence (scores/outcomes + today's odds + link); 0 = off
#AUTO_FULL_AT=06:00      # daily full pipeline time, EAT wall-clock (HH:MM); ''/off = off
#AUTO_FULL_DAYS=5        # days ahead for the daily full sweep (= `npm run start -- 5`)
#AUTO_LOG=1              # append per-job lines to logs/auto-refresh.log
#AUTO_LOG_MAX_KB=256     # log self-truncates past this size (host has no rotation)
#ODDS_REFRESH_TIERS=90:0,360:30,1440:120,*:360
                         # decaying backoff for per-game odds DETAIL fetches (light pass only):
                         # CSV upToMin:maxAgeMin - "kickoff <= upTo min away -> refresh only when
                         # last write >= maxAge min old"; first tier 90:0 = always fresh near
                         # kickoff (keeps is_stale current); 'off' = never skip (legacy behavior)
#AUTO_IDLE_LOOKAHEAD_MINUTES=120  # skip the odds+link scrape when nothing is in-play and the next
                                  # kickoff is further than this; 0 = feature off
#AUTO_IDLE_EVERY_MINUTES=60       # while idle, still run a discovery pass this often (new games
                                  # appear intra-day); 0 = never force-run during idle
#REFRESH_CACHE_MINUTES=5 # manual refresh answered "already fresh" (no re-run) when the date
                         # was successfully refreshed - any mode - within this window. 0 = off.

# Visitor geo backfill (src/geo.js): a background sweep resolves new visitor IPs
# to country/region and caches each per-IP (ip_geo), marking private/unresolvable
# so they're skipped later. Runs alongside the server; `node src/index.js geo`
# forces one pass. Only fires when there are PUBLIC IPs to resolve (localhost-only
# dev makes no external calls). NOTE: the default provider (ip-api.com free tier)
# is HTTP-only and no-key, so visitor IPs are sent to a third party - point
# GEO_API_BATCH_URL at a keyed HTTPS or self-hosted resolver to change that.
#GEO_RESOLVE_ENABLED=1    # master switch for the background geo backfill
#GEO_INTERVAL_MINUTES=10  # sweep cadence
#GEO_BATCH_LIMIT=100      # IPs resolved per sweep (ip-api batch cap = 100)
#GEO_API_BATCH_URL=http://ip-api.com/batch  # POST batch endpoint (ip-api.com shape)

# Safe-only slip-leg selection (the web's 🛡 Safe-only toggle). Served to the
# browser via /api/magic-sort, so a change takes effect on the next server
# restart (no web rebuild). Defaults = DEFAULT_SAFE in src/db/magic-rules.js.
# Re-tune the gate thresholds from `node scripts/analyze-safe-tips.js`.
#SAFE_MAX_PER_DAY=3      # how many safe picks per day (the "best N per day" cap)
#SAFE_STRATEGY=sure      # ranking that decides who wins the cap (any magic strategy id)
#SAFE_MIN_PARTS=2        # min blend components present (1-3): 3 = all of odds/form/expert
#SAFE_MIN_AGREEMENT=0.65 # floor on the weakest present component
#SAFE_MAX_PRICE=1.6      # only include legs priced at/below this
#SAFE_MIN_SAMPLES=6      # stats-sufficiency gate: min rolling sample per side (0 = off)
#SAFE_MIN_H2H=0          # stats-sufficiency gate: min head-to-head meetings (0 = off)
#SAFE_MIN_MARKET_SETTLED=30 # maturity floor: min settled live tips for a market before it can win the cap (0 = off)

# Web dashboard branding - VITE_* are baked into web/dist at BUILD time
# (client-only; rebuild `npm run build:web` and redeploy web/dist after changes).
#VITE_GA_ID=G-2CNKRP1W0Q   # Google Analytics 4 measurement ID (unset = no analytics; injected in prod builds only)
#VITE_APP_NAME=Odds Pro    # dashboard title base; the package.json version appends " vX.Y.Z"
#VITE_DEMO_VIDEO_URL=https://www.youtube.com/watch?v=xxxxxxxxxxx  # Help modal demo video (unset = "coming soon" placeholder)
#VITE_SHOW_DETAILS=0       # 0 = hide internal reasoning (TipPopover blend/gate/AI + Magic-sort methodology). DEFAULT ON (unset/1 shows details)

# knex pool sizing (knexfile.js) - defaults preserve the existing hardcoded 0/10.
# The cron pipeline (npm run start) and the always-on server (npm run serve) are
# SEPARATE processes with separate pools - shared hosting caps per-account MySQL
# connections, so tune both down (e.g. 3) if you hit connection-limit errors.
#DB_POOL_MIN=0
#DB_POOL_MAX=10

# Self-apply pending knex migrations when `npm run serve` boots (fail-fast on
# error). OFF by default - local/dev restarts never migrate. Set on a shell-less
# host (cPanel) so a Restart runs migrate:latest. See docs/DEPLOYMENT.md §5.
#MIGRATE_ON_BOOT=0

# SPA bot-protection (opt-in; all OFF by default). See docs/DEPLOYMENT.md §8.
# NOTE: the proof-of-work human gate (HUMAN_POW_* / VITE_HUMAN_POW) was REMOVED
# 2026-07-16 - deprecated as irrelevant at this stage. Leftover HUMAN_* lines in
# an existing .env are ignored (the config schema strips unknown keys).
# Known-bot user-agent blocklist + AI-crawler robots.txt (src/bot-rules.js).
#BOT_UA_FILTER_ENABLED=0       # 1 = 403 known AI scrapers / crawlers / raw HTTP clients (Googlebot etc. left alone)
#BOT_UA_EXTRA=                 # comma-separated extra UA substrings to block
#BOT_UA_ALLOW=                 # comma-separated UA substrings to exempt (wins over the built-in list)

# --- User accounts / auth (v1.1.0) ------------------------------------------
# PIN_PEPPER is mixed into every scrypt PIN hash. STRONGLY recommended in prod.
# ⚠ SECURITY: changing it later invalidates every stored PIN (a global reset).
# Set it BEFORE `npm run migrate` seeds the admin, or the seeded admin's PIN
# won't verify after you add a pepper.
#PIN_PEPPER=                    # long random string; keep secret, gitignored
#ADMIN_SEED_PIN=0000            # first-login bootstrap PIN for the seeded admin (must_change_pin forces a reset)
#AUTH_ENABLED=1                 # master switch for the user-accounts feature
#SESSION_TTL_DAYS=30
#PIN_MAX_ATTEMPTS=5             # wrong PINs before a temporary account lockout
#PIN_LOCKOUT_MINUTES=15

# --- SMS provider + OTP (v1.1.0; src/sms/*, src/db/sms-rules.js) -------------
# Used only for phone-verification OTPs. OFF by default: with SMS_ENABLED off,
# NO network call is made and the OTP is logged to the server console (dev).
#SMS_ENABLED=0
#SMS_DEFAULT_REGION=KE
# Bonga SMS creds (https://app.bongasms.co.ke/clients/developer).
#BONGA_API_CLIENT_ID=
#BONGA_API_KEY=
#BONGA_API_SECRET=
#BONGA_SERVICE_ID=1
# ⚠ SECURITY - CLEARTEXT: Bonga's vendor-published SEND host is plain HTTP (an
#   IP:port with NO TLS), so the API secret + recipient number + message travel
#   UNENCRYPTED on the wire. balance/delivery are HTTPS. There is no TLS send
#   endpoint from the vendor; the send path logs a one-time warning. To protect
#   credentials, point BONGA_API_URL_SEND at an HTTPS proxy YOU operate that
#   forwards to the Bonga host. Loopback (a local proxy) is exempt from the warning.
#BONGA_API_URL_SEND=http://167.172.14.50:4002/v1/send-sms   # override with your https:// proxy
#BONGA_API_URL_BALANCE=https://app.bongasms.co.ke/api/check-credits
#BONGA_API_URL_DELIVERY=https://app.bongasms.co.ke/api/fetch-delivery
# OTP policy.
#OTP_TTL_MINUTES=10
#OTP_LENGTH=6
#OTP_MAX_ATTEMPTS=5            # wrong codes before a fresh one is required
#OTP_RESEND_BASE_SECONDS=60   # resend backoff grows 60·n (60,120,180,...)
#OTP_MAX_RESENDS=5
