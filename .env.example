# =============================================================================
# oddspro .env  -  SECRETS, ENDPOINTS, BOOT INFRA and BUILD-TIME flags only.
# =============================================================================
# RUNTIME TUNING KNOBS DO NOT BELONG HERE ANY MORE.
#
# Since v1.1.0 (M6) ~82 runtime knobs - every AI / hot-pick / tip / safe-pool /
# refresh / geo / bot / OTP / SMS / maintenance / logging setting - are edited in
# the app at **Admin -> Settings**, persisted in the `settings` table and merged
# over the code defaults. Most take effect immediately (`live`); the few that are
# read once at boot are badged "restart required" in that editor. Every change is
# dated in `admin_audit`, which an untracked .env edit can never be.
#
# Both entrypoints load those overrides (`src/index.js` CLI and `src/server.js`
# serve), so an Admin -> Settings value applies to `npm run start` cron runs too.
# `.env` remains only the FALLBACK layer beneath them - useful before the first
# migration, or when the DB is unreachable.
#
# What still belongs in this file: credentials, API endpoints, things read before
# the DB exists (ports, pool sizing, migrate-on-boot, the PIN pepper) and VITE_*
# (baked into web/dist at BUILD time). That is what is listed below.
#
# Keep the real values here (this file is the gitignored .env's template) and
# NEVER commit a filled-in copy.
# =============================================================================


# --- MySQL connection --------------------------------------------------------
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=oddspro
DB_USERNAME=root
DB_PASSWORD=
DB_CHARSET=utf8mb4
DB_COLLATION=utf8mb4_unicode_ci

# knex pool sizing (knexfile.js); defaults preserve the historic 0/10.
# The cron pipeline (npm run start) and the always-on server (npm run serve) are
# SEPARATE processes with SEPARATE pools - shared hosting caps per-account MySQL
# connections, so tune BOTH down (e.g. 3) if you hit connection-limit errors.
#DB_POOL_MIN=0
#DB_POOL_MAX=10


# --- API-Football via api-sports.io ------------------------------------------
# https://dashboard.api-football.com
X_APISPORTS_URL=https://v3.football.api-sports.io
X_APISPORTS_KEY=your-api-key


# --- AI providers: KEYS + ENDPOINTS ------------------------------------------
# Model choice, caps, concurrency, grounding and every other AI knob now live in
# Admin -> Settings (groups `ai` and `ai-dark`). Only the secrets are below.
#
# COST WARNING. AI spend is driven almost entirely by the caps in Admin ->
# Settings, not by anything here. The economical baseline the repo now ships:
#   AI_ENRICH_CAP=40   (fits OpenRouter's free tier, see below)
#   TIP_AI_DAILY_CAP   small (default 20) - fresh/billed verdicts per EAT day;
#                      reused verdicts are free and do not count
#   AI_CONSENSUS_*     OFF - consensus panels multiply cost per verdict
# Raising a cap raises a real bill. Review it in Admin -> Settings, where the
# change is dated in `admin_audit`.

# Google Gemini - adjudicators (hot picks + tips) and the facts/anchored
# enrichment calls. No key = rules-only verdicts, which is a supported mode.
# https://aistudio.google.com/apikey
#GEMINI_API_KEY=your-gemini-key
#GEMINI_URL=https://generativelanguage.googleapis.com/v1beta
# NOTE (deprecation): gemini-2.5-flash - the current HOTPICK_AI_MODEL default -
# is scheduled for retirement 2026-10-16. A model change is coming regardless of
# cost tuning; it is a POLICY-REGIME change (the model name is baked into the
# reuse tag, so switching triggers one bounded re-adjudication wave and forks the
# measurement population). Date it in docs/memory-bank.md when you make it.

# OpenRouter - the BLIND reasoner slot ONLY. It must stay a NON-Google model:
# reasoner independence is the whole point of the blind-vs-anchored comparison,
# and `resolveTask` refuses a Google model at boot. Auto-routers
# (openrouter/auto, openrouter/free) are disqualified - the model varies per call,
# so the reuse tag would lie.
# The shipped default is a FREE model (nvidia/nemotron-3-super-120b-a12b:free).
# Free tier is roughly 50 requests/day, which is why AI_ENRICH_CAP defaults to
# 40: `src/enrich.js` fails OPEN on a 429, so going over the limit would SILENTLY
# truncate blind coverage rather than error.
#OPENROUTER_API_KEY=
#OPENROUTER_URL=https://openrouter.ai/api/v1


# --- Bookmaker API endpoints -------------------------------------------------
# Undocumented public APIs; override only if a base path moves.
#BETPAWA_BASE_URL=https://www.betpawa.co.ke/api/sportsbook/v4
#BETIKA_BASE_URL=https://api.betika.com/v1/uo


# --- Server / boot infra -----------------------------------------------------
#API_PORT=3001        # PORT wins if API_PORT is unset (cPanel/Passenger assigns PORT)
#API_HOST=127.0.0.1   # 0.0.0.0 exposes the dashboard + refresh endpoint on the LAN.
# Reverse-proxy hops to trust for req.ip / X-Forwarded-For. MUST be a COUNT,
# never `true`: trusting every proxy makes req.ip the leftmost XFF entry, which
# the client writes, so every IP rate limit (signup, forgot-PIN, beacons)
# becomes bypassable by rotating one header - and signup spends real SMS credit
# to a caller-chosen number. 1 = one proxy (cPanel/Passenger, the default).
# Set 2 behind Cloudflare, 0 if the server is exposed directly.
#TRUST_PROXY=1
                      # Leave 127.0.0.1 on cPanel/Passenger - it proxies over loopback.
#API_TOKEN=           # optional: require `Authorization: Bearer <token>` on ALL /api/*.
                      # Gates the public SPA too (web/src/api.js sends VITE_API_TOKEN,
                      # baked in at build time), so setting it closes the site.
#ADMIN_TOKEN=         # optional: machine bearer for the admin endpoints. SEPARATE from
                      # API_TOKEN so a public SPA stays open while admin views are locked;
                      # falls back to API_TOKEN. Unset (and no API_TOKEN) = admin 404.

# Self-apply pending knex migrations when `npm run serve` boots (fail-fast on
# error). OFF by default - local/dev restarts never migrate. Set this on a
# shell-less host (cPanel) so a Restart runs migrate:latest. docs/DEPLOYMENT.md §5.
#MIGRATE_ON_BOOT=0


# --- User accounts / auth: BOOTSTRAP SECRETS ---------------------------------
# Policy knobs (session TTL, lockout attempts/minutes) are in Admin -> Settings
# (group `auth-policy`). These three cannot be, by construction.
#
# PIN_PEPPER is mixed into every scrypt PIN hash and is effectively REQUIRED in
# prod (the server warns loudly at boot when unset).
# ⚠ Set it BEFORE `npm run migrate` seeds the admin, or the seeded admin's PIN
#   will not verify. Changing it later invalidates EVERY stored PIN - a global
#   credential reset. Recovery tool: `node scripts/reset-users.js`.
#PIN_PEPPER=                # long random string; secret, gitignored
#ADMIN_SEED_PIN=0000        # bootstrap PIN for the seeded admin; first login forces a change
#AUTH_ENABLED=1             # master switch; 0 restores legacy anonymous full access.
                            # Deliberately NOT admin-editable - it gates the admin UI itself.


# --- SMS provider (Bonga): CREDENTIALS + ENDPOINTS ---------------------------
# Used for phone-verification OTPs and M9 broadcast campaigns. The SMS_ENABLED
# switch, default region, service id, batch sizing and breaker are in
# Admin -> Settings (group `sms`). With SMS disabled NO network call is made and
# the OTP is logged to the server console - the supported dev mode.
# https://app.bongasms.co.ke/clients/developer
#BONGA_API_CLIENT_ID=
#BONGA_API_KEY=
#BONGA_API_SECRET=
# ⚠ SECURITY - CLEARTEXT: Bonga's vendor-published SEND host is plain HTTP (an
#   IP:port with NO TLS), so the API secret, recipient number and message travel
#   UNENCRYPTED. balance/delivery are HTTPS. The vendor offers no TLS send
#   endpoint; the send path logs a one-time warning. To protect the credentials,
#   point BONGA_API_URL_SEND at an HTTPS proxy YOU operate that forwards to the
#   Bonga host. Loopback (a local proxy) is exempt from the warning.
#BONGA_API_URL_SEND=http://167.172.14.50:4002/v1/send-sms   # override with your https:// proxy
#BONGA_API_URL_BALANCE=https://app.bongasms.co.ke/api/check-credits
#BONGA_API_URL_DELIVERY=https://app.bongasms.co.ke/api/fetch-delivery


# --- Email (M13): CREDENTIALS ------------------------------------------------
# OTP fallback when SMS cannot reach a user, plus Forgot-PIN and PIN-change codes.
# The MAIL_MAILER switch is in Admin -> Settings (group `mail`); the credentials
# below are .env-ONLY and deliberately absent from the settings catalog.
# MAIL_MAILER=log (the default) prints emails to the server console and makes NO
# network call - the ergonomic twin of SMS disabled. `smtp` sends for real.
#MAIL_HOST=smtp.example.com
#MAIL_PORT=587
#MAIL_USERNAME=
#MAIL_PASSWORD=
#MAIL_ENCRYPTION=tls            # tls = STARTTLS (587) | ssl = implicit TLS (465)
#MAIL_SCHEME=                   # optional Laravel-style alternative: smtp | smtps
#MAIL_FROM_ADDRESS=no-reply@example.com
#MAIL_FROM_NAME="Odds Pro"


# --- Web dashboard: BUILD-TIME flags -----------------------------------------
# VITE_* are baked into web/dist when you run `npm run build:web`. They are NOT
# runtime settings - rebuild and redeploy web/dist after changing any of them.
#VITE_GA_ID=G-2CNKRP1W0Q   # GA4 measurement ID (unset = no analytics; prod builds only)
#VITE_APP_NAME=Odds Pro    # dashboard title base; package.json version appends " vX.Y.Z"
#VITE_DEMO_VIDEO_URL=https://www.youtube.com/watch?v=xxxxxxxxxxx  # Help modal demo (unset = placeholder)
#VITE_SHOW_DETAILS=0       # 0 = hide internal reasoning (TipPopover blend/gate/AI +
                           # magic-sort methodology). DEFAULT ON (unset/1 shows details).
                           # Prod sets 0 - the prediction logic is a guarded secret.


# --- Local development convenience -------------------------------------------
# Both of these ARE editable in Admin -> Settings; they are repeated here only
# because a local checkout usually wants them set before the server ever boots.
#AUTO_REFRESH_ENABLED=0   # STRONGLY recommended locally: the in-process scheduler
                          # otherwise fires live scraping / API / AI calls in the
                          # background. Restart required (also badged in the editor).
#DEBUG=1                  # verbose per-step timing (pipeline, saveMatches, hotpicks).
                          # The main diagnostic channel on hosts with no SSH.
