# ============================================================================
# oddspro - PRODUCTION environment template
# ----------------------------------------------------------------------------
# Copy to `.env` on the production host (the Node server reads `.env` via
# dotenv). The web build (`npm run build:web`, Vite production mode) reads the
# SAME `.env` for its VITE_* vars - so build the frontend from the same file
# the server runs, and the two stay in lock-step.
#
# `.env.production` (this file's real, secret-filled twin) is GITIGNORED - never
# commit real keys. This `.example` is the committed reference only.
#
# ============================================================================

# --- MySQL (production DB) --------------------------------------------------
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=oddspro
DB_USERNAME=CHANGE_ME
DB_PASSWORD=CHANGE_ME
DB_CHARSET=utf8mb4
DB_COLLATION=utf8mb4_unicode_ci

# --- API-Football -----------------------------------------------------------
X_APISPORTS_URL=https://v3.football.api-sports.io
X_APISPORTS_KEY=CHANGE_ME

# --- Server binding ---------------------------------------------------------
# Behind cPanel/Passenger keep loopback; PORT is assigned by the host if unset.
API_HOST=127.0.0.1
#API_PORT=3001

# Apply pending knex migrations on server boot (shell-less host: a Restart
# runs migrate:latest). Recommended ON in production. See docs/DEPLOYMENT.md §5.
MIGRATE_ON_BOOT=1

# --- SPA bot-protection -----------------------------------------------------
# NOTE: the proof-of-work human gate (HUMAN_POW_ENABLED / VITE_HUMAN_POW /
# HUMAN_TOKEN_SECRET / HUMAN_POW_BITS / HUMAN_TOKEN_TTL_DAYS /
# HUMAN_CHALLENGE_TTL_MINUTES) was REMOVED 2026-07-16 - deprecated as
# irrelevant at this stage. Drop those lines from any real .env.production:
# they are now ignored, and the "#1 deploy gotcha" they caused is gone with them.
# The UA blocklist below is a separate feature and is unaffected.

# Known-bot user-agent blocklist + AI-crawler robots.txt (Googlebot/Bingbot exempt).
BOT_UA_FILTER_ENABLED=1
#BOT_UA_EXTRA=                # comma-separated extra UA substrings to block
#BOT_UA_ALLOW=                # comma-separated UA substrings to exempt

# --- Admin dashboard --------------------------------------------------------
# Guards GET /admin + /api/visits/summary. Leave API_TOKEN UNSET in production:
# it locks down the WHOLE /api and would break public guest browsing.
ADMIN_TOKEN=CHANGE_ME
#API_TOKEN=                   # ⚠ leave unset - mutually exclusive with public/guest browsing

# --- Optional: AI adjudicators (Gemini) -------------------------------------
#GEMINI_API_KEY=CHANGE_ME

# --- Web branding (VITE_*, baked into web/dist at build time) ---------------
#VITE_APP_NAME=Odds Pro
#VITE_GA_ID=G-XXXXXXXXXX
#VITE_SHOW_DETAILS=0          # 0 = hide internal reasoning in the public build

# --- User accounts / auth (v1.1.0) ------------------------------------------
# AUTH_ENABLED defaults ON. PIN_PEPPER is REQUIRED in production - without it
# PIN hashes carry no server pepper (the server warns loudly at boot). ⚠ Set it
# BEFORE the users migration seeds the admin, and NEVER change it afterwards:
# a changed pepper invalidates EVERY stored PIN (a deliberate global reset).
AUTH_ENABLED=1
PIN_PEPPER=CHANGE_ME          # node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ADMIN_SEED_PIN=CHANGE_ME      # exactly 4 digits; the seeded admin must change it on first login
#SESSION_TTL_DAYS=30
#PIN_MAX_ATTEMPTS=5
#PIN_LOCKOUT_MINUTES=15

# --- SMS OTP (phone verification; Bonga) ------------------------------------
# With SMS off the OTP is only logged to the server console - fine in dev,
# useless for real visitors. Production sign-ups need SMS_ENABLED=1 + creds
# (missing creds fail closed with a clear error). ⚠ CLEARTEXT: Bonga's vendor
# SEND host is plain http:// - route BONGA_API_URL_SEND through an HTTPS proxy
# you control (details in .env.example).
SMS_ENABLED=1
SMS_DEFAULT_REGION=KE
BONGA_API_CLIENT_ID=CHANGE_ME
BONGA_API_KEY=CHANGE_ME
BONGA_API_SECRET=CHANGE_ME
BONGA_SERVICE_ID=1
#BONGA_API_URL_SEND=          # your https:// proxy to the Bonga send host
#OTP_TTL_MINUTES=10
#OTP_LENGTH=6
#OTP_MAX_ATTEMPTS=5
#OTP_RESEND_BASE_SECONDS=60
#OTP_MAX_RESENDS=5
